# Backend Environment
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://mcd_user:mcd_password@localhost:5432/mcd_db

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRY=7d

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Redis
REDIS_URL=redis://localhost:6379

# OAuth (Optional)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=

# Email Service (Optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# File Storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
